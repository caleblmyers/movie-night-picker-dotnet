@page "/suggest/rounds"
@using MovieNightPicker.Web.Services
@inject HttpClient Http

<PageTitle>Suggestion rounds</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Find your movie</h1>
    <button class="btn btn-outline-secondary btn-sm" @onclick="StartOverAsync">Start over</button>
</div>

<ApiErrorBoundary @bind-Message="error" />

@if (finished)
{
    <h2 class="h4">We recommend</h2>
    @if (recommendation is not null)
    {
        <div class="col-md-4 mb-3">
            <MovieCard Movie="recommendation" />
        </div>
    }
    else
    {
        <p class="text-muted">We couldn't find a recommendation from those picks.</p>
    }
    <button class="btn btn-primary" @onclick="StartOverAsync">Start again</button>
}
else
{
    <div class="progress mb-2" role="progressbar" aria-label="Round progress">
        <div class="progress-bar" style="width:@(round * 10)%">Round @round of @TotalRounds</div>
    </div>

    @if (loading)
    {
        <p class="text-muted">Loading round @round…</p>
    }
    else if (currentRound is { Movies.Count: > 0 })
    {
        <h2 class="h4">@currentRound.CategoryLabel</h2>
        <p class="text-muted">Pick the one you like most — or skip to the recommendation.</p>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-3 mb-3">
            @foreach (var movie in currentRound.Movies)
            {
                <div class="col">
                    <MovieCard Movie="movie">
                        <Actions Context="m">
                            <button class="btn btn-sm btn-success" @onclick="() => PickAsync(m)">Pick</button>
                        </Actions>
                    </MovieCard>
                </div>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="SkipAsync">
                @(round >= TotalRounds ? "Skip & recommend" : "Skip this round")
            </button>
            <button class="btn btn-outline-primary" @onclick="FinishAsync" disabled="@(selectedIds.Count == 0)">
                Finish &amp; recommend now
            </button>
        </div>
    }
    else
    {
        <p class="text-muted">No movies for this round.</p>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="SkipAsync">
                @(round >= TotalRounds ? "Skip & recommend" : "Skip this round")
            </button>
            <button class="btn btn-outline-primary" @onclick="FinishAsync" disabled="@(selectedIds.Count == 0)">
                Finish &amp; recommend now
            </button>
        </div>
    }
}

@code {
    private const int TotalRounds = 10;

    private SuggestApiClient client = default!;

    private int round = 1;
    private readonly List<int> selectedIds = [];

    private SuggestRound? currentRound;
    private bool loading;

    private bool finished;
    private MovieSummary? recommendation;

    private string? error;

    protected override void OnInitialized() => client = new SuggestApiClient(Http);

    protected override Task OnInitializedAsync() => LoadRoundAsync();

    private async Task LoadRoundAsync()
    {
        loading = true;
        error = null;
        var result = await ApiCall.RunAsync(() => client.GetRoundAsync(round, selectedIds));
        if (result.Succeeded)
        {
            currentRound = result.Value;
        }
        else
        {
            error = result.Error;
        }
        loading = false;
    }

    private async Task PickAsync(MovieSummary movie)
    {
        selectedIds.Add(movie.Id);
        await AdvanceAsync();
    }

    /// <summary>Skip the current round without recording a pick.</summary>
    private Task SkipAsync() => AdvanceAsync();

    /// <summary>Move to the next round, or finish if this was the last one.</summary>
    private async Task AdvanceAsync()
    {
        if (round >= TotalRounds)
        {
            await FinishAsync();
            return;
        }

        round++;
        await LoadRoundAsync();
    }

    private async Task FinishAsync()
    {
        loading = true;
        error = null;
        var result = await ApiCall.RunAsync(() => client.SuggestAsync(selectedIds));
        if (result.Succeeded)
        {
            recommendation = result.Value;
            finished = true;
        }
        else
        {
            error = result.Error;
        }
        loading = false;
    }

    private async Task StartOverAsync()
    {
        round = 1;
        selectedIds.Clear();
        finished = false;
        recommendation = null;
        await LoadRoundAsync();
    }
}
